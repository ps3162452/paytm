<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@+id/linear1"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/linear9"
            android:background="#ffffff"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/imageview8"
                android:layout_width="250dp"
                android:layout_height="50dp"
                android:src="@drawable/hhgu"
                android:scaleType="fitCenter"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/linear10"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/linear27"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/hide"
                    android:background="#ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <Button
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:id="@+id/button1"
                        android:background="#2196f3"
                        android:padding="8dp"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:text="PAYTM START"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:id="@+id/textview21"
                        android:padding="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="50dp"
                        android:text="⛔Terms and conditions⛔:-\10I will not take any responsibility if any kind of scam or fraudulent happens to anyone from this application, this app is only for education and fun purposes. Don&apos;t use it for any misleading purposes if you harm anyone the developer/provider is not liable for it, you are totally liable for it.\10\10Bʏ @priyankafalcon✅"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/linear13"
                    android:background="#ffffff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/linear19"
                        android:layout_width="match_parent"
                        android:layout_height="250dp">
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/linear20"
                            android:background="#ffffff"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginRight="10dp">
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:id="@+id/linear22"
                                android:background="#1a237e"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="40dp">
                                <TextView
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#f44336"
                                    android:id="@+id/textview15"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="● No Sound Box  ❌️"/>
                            </LinearLayout>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="#000000"
                                android:id="@+id/textview18"
                                android:padding="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="�� Paytm History\10�� 1 Account Bank\10�� Unlimited Money Send\10�� Best Ui Paytm\10�� UTR ID\10"/>
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:id="@+id/linear24"
                                android:background="#40c4ff"
                                android:paddingLeft="8dp"
                                android:paddingTop="4dp"
                                android:paddingRight="8dp"
                                android:paddingBottom="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:layout_marginLeft="10dp"
                                android:layout_marginTop="15dp"
                                android:layout_marginRight="10dp">
                                <TextView
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#ffffff"
                                    android:id="@+id/textview19"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹ 149.00"/>
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/linear21"
                            android:background="#ffffff"
                            android:layout_width="0dp"
                            android:layout_height="0dp">
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:id="@+id/linear23"
                                android:background="#1a237e"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="40dp">
                                <TextView
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#00c853"
                                    android:id="@+id/textview16"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="● Sound Box ON ✅️"/>
                            </LinearLayout>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="#000000"
                                android:id="@+id/textview17"
                                android:padding="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:text="�� Unlimited Sound Box\10�� Unlimited SmS\10�� 3 Bank Account\10�� Paytm History\10�� Check Money"/>
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:id="@+id/linear25"
                                android:background="#40c4ff"
                                android:padding="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:layout_marginLeft="10dp"
                                android:layout_marginTop="18dp"
                                android:layout_marginRight="10dp">
                                <TextView
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#ffffff"
                                    android:id="@+id/textview20"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹ 399.00"/>
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/linear28"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/imageview9"
                                android:layout_width="180dp"
                                android:layout_height="245dp"
                                android:src="@drawable/dff_2"
                                android:scaleType="fitXY"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/linear29"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/imageview10"
                                android:layout_width="180dp"
                                android:layout_height="240dp"
                                android:src="@drawable/dff_1"
                                android:scaleType="fitXY"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/linear14"
                        android:padding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginLeft="40dp"
                        android:layout_marginRight="40dp">
                        <EditText
                            android:textSize="16sp"
                            android:textColor="#ffffff"
                            android:textColorHint="#ffffff"
                            android:id="@+id/edittext1"
                            android:padding="8dp"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:text="XIONMAFIA"
                            android:hint="Enter Your key"
                            android:alpha="0"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/linear15"
                        android:background="#ffffff"
                        android:padding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginLeft="50dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="50dp">
                        <TextView
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:id="@+id/textview1"
                            android:padding="8dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatic Login"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:id="@+id/textview14"
                        android:padding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:text="OK"/>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/linear16"
                        android:background="#ff9800"
                        android:padding="8dp"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginLeft="50dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="50dp">
                        <TextView
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/textview2"
                            android:padding="8dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KEY BUY NOW"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/linear17"
                        android:background="#f44336"
                        android:padding="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="50dp"
                        android:layout_marginRight="50dp">
                        <TextView
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:id="@+id/textview3"
                            android:padding="8dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOW TO BUY VIDEO"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/linear18"
                        android:padding="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">
                        <ImageView
                            android:id="@+id/imageview5"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/youtube"
                            android:scaleType="fitXY"/>
                        <ImageView
                            android:id="@+id/imageview6"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="20dp"
                            android:src="@drawable/instagram"
                            android:scaleType="fitXY"/>
                        <ImageView
                            android:id="@+id/imageview7"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="20dp"
                            android:src="@drawable/ic_telegram_official"
                            android:scaleType="fitXY"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
